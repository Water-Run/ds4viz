# ds4viz Docker 环境变量示例
# 复制为 .env 并按需修改

# ---------- PostgreSQL ----------
POSTGRES_DB=ds4viz_dev
POSTGRES_USER=ds4viz
POSTGRES_PASSWORD=ds4viz_dev_pwd
POSTGRES_PORT=5432

# ---------- 后端 ----------
BACKEND_PORT=10000
PYTHON_VERSION=3.12

# ---------- 前端 ----------
FRONTEND_PORT=5173
NODE_VERSION=22
# 前端访问后端的根地址, 浏览器通过 nginx 走 /api 反代时可不改
VITE_API_BASE=http://localhost:10000